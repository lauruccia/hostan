            if (!empty($notification) && data_get($notification, 'enabled_email') == 1) {
                // Check if maintainer_id is valid (not 0 or null)
                if (!empty($maintenanceRequest->maintainer_id) && $maintenanceRequest->maintainer_id > 0) {
                    $maintainerUser = User::find($maintenanceRequest->maintainer_id);
                    if ($maintainerUser && !empty($maintainerUser->email)) {
                        try {
                            $notification_response = MessageReplace($notification, $maintenanceRequest->id);
                            
                            $datas['subject'] = data_get($notification_response, 'subject');
                            $datas['message'] = data_get($notification_response, 'message');
                            $datas['module']  = $module;
                            $datas['logo']    = $setting['company_logo'] ?? null;
                            $to = $maintainerUser->email;
                            
                            // Get maintainer's language preference
                            $userLanguage = $maintainerUser->lang ?? null;
                            
                            $response = commonEmailSend($to, $datas, $userLanguage);
                            if (isset($response['status']) && $response['status'] == 'error') {
                                $errorMessage .= ($errorMessage ? '<br>' : '') . $response['message'];
                            }
                        } catch (\Exception $e) {
                            Log::error('Failed to send maintainer deletion notification', [
                                'error' => $e->getMessage(),
                                'maintenance_request_id' => $maintenanceRequest->id
                            ]);
                        }
                    }
                }
            }
            
            $maintenanceRequest->delete();
            return redirect()->back()->with('success', __('Maintenance request successfully deleted.') . ($errorMessage ? '</br>' . $errorMessage : ''));
        } else {
            return redirect()->back()->with('error', __('Permission Denied!'));
        }
    }

