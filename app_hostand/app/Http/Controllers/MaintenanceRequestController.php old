public function update(Request $request, MaintenanceRequest $maintenanceRequest)
{
    if (!\Auth::user()->can('edit maintenance request')) {
        return redirect()->back()->with('error', __('Permission Denied!'));
    }

    // Validation (mirror store validation + update-specific rules)
    $validator = \Validator::make($request->all(), [
        'property_id'   => 'required',
        'unit_id'       => 'required',
        'issue_type'    => 'required',
        'maintainer_id' => Auth::user()->type != 'owner' ?'required':'nullable',
        // 'request_date'  => 'required|date',
        'people_count'  => 'nullable|in:1,2,3,4,5,6,7',
        'arrival_time'  => 'nullable|date',
        'issue_attachment' => 'nullable|file', // optional - adjust rules if needed
    ]);

    if ($validator->fails()) {
        $messages = $validator->getMessageBag();
        return redirect()->back()->with('error', $messages->first());
    }

    // ✅ Get the configured timezone from settings
    $settings = settings();
    $timezone = !empty($settings['timezone']) && trim($settings['timezone']) !== '' 
        ? trim($settings['timezone']) 
        : config('app.timezone', 'UTC');
    
    // Validate timezone - if invalid, use UTC
    try {
        Carbon::now($timezone);
    } catch (\Exception $e) {
        $timezone = 'UTC';
    }
    
    // ✅ Convert arrival_time if provided
    $arrivalTimeUpdated = $request->filled('arrival_time');
    $arrivalTime = $maintenanceRequest->arrival_time; // Keep existing if not updated
    if ($arrivalTimeUpdated) {
        // Parse the datetime string and assume it's in the configured timezone
        $arrivalTime = Carbon::parse($request->arrival_time, $timezone)
            ->setTimezone('UTC')  // Convert to UTC for storage
            ->format('Y-m-d H:i:s');
    }

        // ✅ Validate: Status can only be changed if the arrival date has been reached
        // Only validate if status is being changed
        if ($request->filled('status') && $request->status !== $maintenanceRequest->status && $request->status !== 'pending') {
            // Use the updated arrival_time if it was changed, otherwise use existing
            $checkArrivalTime = $arrivalTimeUpdated ? $arrivalTime : $maintenanceRequest->arrival_time;
            
            if ($checkArrivalTime) {
                // Get user's timezone from settings
                $settings = settings();
                $userTimezone = !empty($settings['timezone']) && trim($settings['timezone']) !== '' 
                    ? trim($settings['timezone']) 
                    : config('app.timezone', 'UTC');
                
                // Validate timezone - if invalid, use UTC
                try {
                    Carbon::now($userTimezone);
                } catch (\Exception $e) {
                    $userTimezone = 'UTC';
                }
                
                // Parse arrival_time (stored in UTC) and convert to user's timezone
                $arrivalTimeUTC = Carbon::parse($checkArrivalTime, 'UTC');
                $arrivalTimeLocal = $arrivalTimeUTC->copy()->setTimezone($userTimezone);
                $currentDateLocal = Carbon::now($userTimezone);
                
                // Get just the date (without time) for comparison
                $arrivalDate = $arrivalTimeLocal->copy()->startOfDay();
                $currentDate = $currentDateLocal->copy()->startOfDay();
                
                // If current date is before arrival date, reject the status change
                if ($currentDate->lt($arrivalDate)) {
                    return redirect()->back()->with('error', __('Status will be changed once the date is reached.'));
                }
            }
    }

    // Update fields (preserve existing if not present)
    $maintenanceRequest->property_id  = $request->property_id;
    $maintenanceRequest->unit_id      = $request->unit_id;
    $maintenanceRequest->service_type   = $request->issue_type;
    
    // If you also use service/service_type field in some places, handle it:
    if ($request->filled('service')) {
        $maintenanceRequest->service_type = $request->service;
    }
    if (\Auth::user()->type == 'owner') {
    // Keep existing maintainer if owner does not send one
    $maintenanceRequest->maintainer_id = $maintenanceRequest->maintainer_id;
    } else {
        $maintenanceRequest->maintainer_id = $request->maintainer_id;
    }

    $maintenanceRequest->people_count  = $request->people_count ?? $maintenanceRequest->people_count;
    $maintenanceRequest->arrival_time  = $arrivalTime; // ✅ Now timezone-aware!
    // $maintenanceRequest->request_date  = $request->request_date;
    $maintenanceRequest->status        = $request->status ?? $maintenanceRequest->status;
    $maintenanceRequest->notes         = $request->notes;

    $maintenanceRequest->save();

    // Handle issue_attachment upload (same pattern used in store)
    if ($request->hasFile('issue_attachment')) {
        $requestFilenameWithExt = $request->file('issue_attachment')->getClientOriginalName();
        $requestFilename = pathinfo($requestFilenameWithExt, PATHINFO_FILENAME);
        $requestExtension = $request->file('issue_attachment')->getClientOriginalExtension();
        $requestFileName = $requestFilename . '_' . time() . '.' . $requestExtension;

        // ensure directory exists (optional: you already store into storage/app/upload/issue_attachment)
        $dir = storage_path('app/upload/issue_attachment');
        if (!file_exists($dir)) {
            mkdir($dir, 0777, true);
        }

        // storeAs stores into storage/app/upload/issue_attachment/
        $request->file('issue_attachment')->storeAs('upload/issue_attachment/', $requestFileName);

        // save filename to model
        $maintenanceRequest->issue_attachment = $requestFileName;
        $maintenanceRequest->save();
    }

    // Notifications (robust to $notification being array or object)
    $module = 'maintenance_request_update';
    $notification = Notification::where('parent_id', parentId())
        ->where('module', $module)
        ->first();

    $setting = settings();
    $errorMessage = '';

    // ✅ Send email to maintainer if notification is enabled and maintainer exists
    if (!empty($notification) && data_get($notification, 'enabled_email') == 1) {
        // Check if maintainer_id is valid (not 0 or null)
        if (!empty($maintenanceRequest->maintainer_id) && $maintenanceRequest->maintainer_id > 0) {
            $maintainerUser = User::find($maintenanceRequest->maintainer_id);
            if ($maintainerUser && !empty($maintainerUser->email)) {
            // MessageReplace should accept model or array — keep passing $notification
            $notification_response = MessageReplace($notification, $maintenanceRequest->id);

            $datas['subject'] = data_get($notification_response, 'subject');
            $datas['message'] = data_get($notification_response, 'message');
            $datas['module']  = $module;
            $datas['logo']    = $setting['company_logo'] ?? null;
                $to = $maintainerUser->email;

                // Get maintainer's language preference
                $userLanguage = $maintainerUser->lang ?? null;

                $response = commonEmailSend($to, $datas, $userLanguage);
            if (isset($response['status']) && $response['status'] == 'error') {
                $errorMessage = $response['message'];
                }
            }
        }
    }

    // ✅ Send notification to admin if owner updated the request
    if (Auth::user()->type === 'owner') {
        $adminNotificationResponse = sendAdminNotificationForOwnerAction('update', $maintenanceRequest);
        if ($adminNotificationResponse['status'] == 'error') {
            $errorMessage .= ($errorMessage ? '<br>' : '') . $adminNotificationResponse['message'];
        }
        
        // ✅ Send confirmation email to owner when they edit a service
        $ownerEmail = Auth::user()->email;
        if (!empty($ownerEmail)) {
            try {
                // Get owner name
                $owner = Auth::user();
                $ownerName = trim(($owner->first_name ?? '') . ' ' . ($owner->last_name ?? ''));
                if (empty($ownerName)) {
                    $ownerName = $owner->email ?? __('Owner');
                }
                
                // Load relationships for email content
                if (!$maintenanceRequest->relationLoaded('properties')) {
                    $maintenanceRequest->load('properties');
                }
                if (!$maintenanceRequest->relationLoaded('units')) {
                    $maintenanceRequest->load('units');
                }
                if (!$maintenanceRequest->relationLoaded('types')) {
                    $maintenanceRequest->load('types');
                }
                
                $propertyName = $maintenanceRequest->properties->name ?? 'N/A';
                $unitName = $maintenanceRequest->units->name ?? 'N/A';
                $serviceType = $maintenanceRequest->types->title ?? 'N/A';
                
                $ownerMessage = '<p><strong>' . __('Dear') . ' ' . $ownerName . ',</strong></p>';
                $ownerMessage .= '<p><strong>' . __('Your maintenance request has been successfully updated.') . '</strong></p>';
                $ownerMessage .= '<p><strong>' . __('Request Details:') . '</strong></p>';
                $ownerMessage .= '<ul>';
                $ownerMessage .= '<li><strong>' . __('Property:') . '</strong> ' . $propertyName . '</li>';
                $ownerMessage .= '<li><strong>' . __('Unit:') . '</strong> ' . $unitName . '</li>';
                $ownerMessage .= '<li><strong>' . __('Service Type:') . '</strong> ' . $serviceType . '</li>';
                if ($maintenanceRequest->arrival_time) {
                    $settings = settings();
                    $timezone = !empty($settings['timezone']) && trim($settings['timezone']) !== '' 
                        ? trim($settings['timezone']) 
                        : config('app.timezone', 'UTC');
                    try {
                        Carbon::now($timezone);
                    } catch (\Exception $e) {
                        $timezone = 'UTC';
                    }
                    $arrivalTime = Carbon::parse($maintenanceRequest->arrival_time, 'UTC')
                        ->setTimezone($timezone)
                        ->format('Y-m-d H:i:s');
                    $ownerMessage .= '<li><strong>' . __('Arrival Time:') . '</strong> ' . $arrivalTime . '</li>';
                }
                if ($maintenanceRequest->status) {
                    $statusKey = MaintenanceRequest::$status[$maintenanceRequest->status] ?? $maintenanceRequest->status;
                    $statusText = __($statusKey); // Translate status
                    $ownerMessage .= '<li><strong>' . __('Status:') . '</strong> ' . $statusText . '</li>';
                }
                $ownerMessage .= '</ul>';
                
                $ownerDatas = [
                    'subject' => __('Maintenance Request Updated - Confirmation'),
                    'message' => $ownerMessage,
                    'module' => 'maintenance_request_update',
                    'logo' => $setting['company_logo'] ?? null,
                ];
                
                // Get owner's language preference
                $ownerLanguage = $owner->lang ?? null;
                
                $ownerResponse = commonEmailSend($ownerEmail, $ownerDatas, $ownerLanguage);
                if (isset($ownerResponse['status']) && $ownerResponse['status'] == 'error') {
                    $errorMessage .= ($errorMessage ? '<br>' : '') . $ownerResponse['message'];
                }
            } catch (\Exception $e) {
                Log::error('Failed to send owner confirmation email', [
                    'error' => $e->getMessage(),
                    'owner_id' => Auth::user()->id,
                    'maintenance_request_id' => $maintenanceRequest->id
                ]);
            }
        }
    }

    return redirect()->back()->with('success', __('Maintenance request successfully updated.') . '</br>' . $errorMessage);
}


