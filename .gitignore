# ===== Solo locale: dati, screenshot, report (NON versionare) =====
/Database
/*.png
/REPORT_SICUREZZA_hostand.md

# ===== Dipendenze =====
/app_hostand/node_modules
# NB: app_hostand/vendor NON è ignorato: il server non ha Composer, va deployato.

# ===== Segreti (mai su GitHub) =====
/app_hostand/.env
/app_hostand/.env.*
!/app_hostand/.env.example

# ===== Runtime: mantiene le cartelle (.gitkeep) ma ignora i contenuti =====
/app_hostand/storage/app/*
!/app_hostand/storage/app/.gitkeep
!/app_hostand/storage/app/public/
/app_hostand/storage/app/public/*
!/app_hostand/storage/app/public/.gitkeep
/app_hostand/storage/framework/cache/*
!/app_hostand/storage/framework/cache/.gitkeep
!/app_hostand/storage/framework/cache/data/
/app_hostand/storage/framework/cache/data/*
!/app_hostand/storage/framework/cache/data/.gitkeep
/app_hostand/storage/framework/sessions/*
!/app_hostand/storage/framework/sessions/.gitkeep
/app_hostand/storage/framework/views/*
!/app_hostand/storage/framework/views/.gitkeep
/app_hostand/storage/framework/testing
/app_hostand/storage/logs/*
!/app_hostand/storage/logs/.gitkeep
/app_hostand/storage/upload
/app_hostand/storage/uploads
/app_hostand/storage/public

# ===== Dati utente nella web root (restano sul server) =====
/public_html/uploads
/public_html/upload
/public_html/assets/images
/public_html/storage

